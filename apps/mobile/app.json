{
  "expo": {
    "name": "Readme",
    "slug": "Readme",
    "androidNavigationBar": {
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#F2F0EF"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bookcommunityapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.bookWorms.BookCommunityApp",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.anonymous.bookcommunityapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCQD-J-vUpor2s48nKErA4zf85wCU-6IHo"
        }
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F2F0EF",
          "image": "./assets/images/splash-light.png",
          "dark": {
            "image": "./assets/images/splash-dark.png",
            "backgroundColor": "#181615"
          },
          "imageWidth": 250
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.849676892747-npd5vr8tm11jem3prh2lmsvlcinn79tp"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs to access your photos so you can choose a profile picture.",
          "cameraPermission": "The app needs to access your camera so you can take a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow BookCommunityApp to use your location to show book distances."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8df3d13f-c2d0-46e7-a23e-5ad2810ebb13"
      }
    },
    "owner": "barrosgoncalo"
  }
}
