rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── REUSABLE SECURITY FUNCTIONS ───
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    function hasProfile() { return exists(/databases/$(database)/documents/users/$(request.auth.uid)); }

    function getMyProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }

    function isAdmin() { return isAuthenticated() && hasProfile() && getMyProfile().role == 'admin'; }
    function isBackOfficer() { return isAuthenticated() && hasProfile() && getMyProfile().role == 'back_officer'; }
    function isActive() { return isAuthenticated() && hasProfile() && getMyProfile().accountStatus == 'active'; }

    // ─── USERS ───
    match /users/{userId} {
      allow read: if isOwner(userId) || (isAuthenticated() && isActive());
      
      allow create: if isOwner(userId) 
                    && request.resource.data.role == 'user' 
                    && request.resource.data.accountStatus == 'active';
      
      allow update: if (isOwner(userId) 
                        && isActive() 
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'accountStatus'])) 
                    || isAdmin();
      
      allow delete: if isOwner(userId) || isAdmin();

      // users/{uid}/blockedUsers/{blockedUid}
      match /blockedUsers/{blockedUid} {
        allow read, create, delete: if isOwner(userId) && isActive();
      }

      // users/{uid}/favoriteBooks/{bookId}
      match /favoriteBooks/{bookId} {
        allow read, write: if isOwner(userId) && isActive();
      }

      // users/{uid}/myBooks/{bookId}
      match /myBooks/{bookId} {
        allow read: if isAuthenticated() && isActive();
        allow write: if isOwner(userId) && isActive();
      }
    }

    // ─── myBooks COLLECTION GROUP (required for collectionGroup queries) ───
    match /{path=**}/myBooks/{bookId} {
      allow read: if isAuthenticated() && isActive();
      allow write: if false; 
    }

   // ─── PUBLICATIONS (NEW POSTS FEATURE) ───
    match /publications/{publicationId} {
      // Any active user can read posts
      allow read: if isAuthenticated() && isActive();
      
      // Users can only create posts under their own UID
      allow create: if isAuthenticated() && isActive() 
                    && request.resource.data.uid == request.auth.uid;
      
      // Update Rule: Owners can update everything. Anyone can update JUST the favoriteCount.
      allow update: if isAuthenticated() && isActive() 
                    && (
                      resource.data.uid == request.auth.uid 
                      // FIX: Changed 'favoriteCount' to 'stats'
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats'])
                      || isAdmin() || isBackOfficer()
                    );

      // Only the author or an admin can delete their post
      allow delete: if isAuthenticated() && isActive() 
                    && (resource.data.uid == request.auth.uid || isAdmin() || isBackOfficer());
    }

    // ─── BOOK CATALOG ───
    match /books/{bookId} {
      allow read: if isAuthenticated() && isActive();
      allow create: if isAuthenticated() && isActive() && request.resource.data.addedBy == request.auth.uid;
      allow update: if (isAuthenticated() && isActive() && resource.data.addedBy == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['addedBy', 'createdAt']))
                    || isAdmin() || isBackOfficer();
      allow delete: if isAdmin() || isBackOfficer();
    }

    // ─── EVENTS ───
    match /events/{eventId} {
      allow read: if isAuthenticated() && isActive();
      allow create: if isAuthenticated() && isActive() && request.resource.data.ownerId == request.auth.uid;
      allow update: if (isAuthenticated() && isActive() && resource.data.ownerId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'createdAt']))
                    || isAdmin() || isBackOfficer();
      allow delete: if isAdmin() || isBackOfficer();

      match /attendees/{attendeeId} {
        allow read: if isAuthenticated() && isActive();
        allow create: if isOwner(attendeeId) && isActive();
        allow delete: if isOwner(attendeeId) || isAdmin() || isBackOfficer();
      }

      match /messages/{msgId} {
        allow read: if isAuthenticated() && isActive();
        allow create: if isAuthenticated() && isActive() && request.resource.data.senderId == request.auth.uid;
        allow delete: if (isAuthenticated() && isActive() && resource.data.senderId == request.auth.uid) || isAdmin() || isBackOfficer();
      }
    }

    // ─── BOOK TRADES ───
    match /trades/{tradeId} {
      allow read: if isAuthenticated() && isActive()
                  && (resource.data.offeredBy == request.auth.uid || resource.data.requestedFrom == request.auth.uid)
                  || isAdmin();

      allow create: if isAuthenticated() && isActive() && request.resource.data.offeredBy == request.auth.uid;

      allow update: if isAuthenticated() && isActive()
                    && (resource.data.offeredBy == request.auth.uid || resource.data.requestedFrom == request.auth.uid)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['bookId', 'offeredBy', 'requestedFrom', 'createdAt']);

      allow delete: if isAdmin();
    }

    // ─── BLOCKS COLLECTION ───
    match /blocks/{blockId} {
      // Allow reading non-existent docs (resource == null) so doIsBlocked()
      // can check membership without a permission error when the doc is absent.
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.blockerUid == request.auth.uid ||
        resource.data.blockedUid == request.auth.uid
      );

      allow create: if isAuthenticated()
        && request.resource.data.blockerUid == request.auth.uid
        && request.resource.data.blockedUid is string
        && request.resource.data.blockerUid != request.resource.data.blockedUid
        && blockId == request.resource.data.blockerUid + '_' + request.resource.data.blockedUid;

      allow delete: if isAuthenticated() && resource.data.blockerUid == request.auth.uid;
      allow update: if false;
    }

    // ─── FOLLOWS ───
    match /follows/{followId} {
      allow read: if isAuthenticated() && isActive();

      allow create: if isAuthenticated() && isActive()
        && request.resource.data.followerUid == request.auth.uid
        && request.resource.data.followingUid is string
        && request.resource.data.followerUid != request.resource.data.followingUid
        && followId == request.resource.data.followerUid + '_' + request.resource.data.followingUid;

      allow delete: if isAuthenticated() && isActive() && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // ─── CHATS & MESSAGES ───
    match /chats/{chatId} {
      allow read, update: if isAuthenticated() && isActive()
                          && request.auth.uid in resource.data.participants;

      allow create: if isAuthenticated() && isActive()
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && isActive()
                           && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ─── REVIEWS ───
    match /reviews/{reviewId} {
      allow read: if isAuthenticated() && isActive();

      allow create: if isAuthenticated() && isActive()
                    && request.resource.data.reviewerId == request.auth.uid;

      allow update, delete: if isAdmin();
    }
  }
}
